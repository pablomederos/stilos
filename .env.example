# Ejemplo de configuración para Stilos

# Configuración de Rate Limiting (Token Bucket)

# Límite máximo de peticiones permitidas en una ráfaga inicial (burst).
RATE_LIMITING_BURST_MAX=100

# Cantidad de peticiones (tokens) que se recargan por cada período de tiempo.
RATE_LIMITING_TOKENS_PER_REFRESH=30

# El período de tiempo (en formato hh:mm:ss) en el que se recargan los tokens.
RATE_LIMITING_REFRESH_INTERVAL=00:00:01
