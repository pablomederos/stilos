@model Stilos.Models.DesignStyle

<div class="demo-wrapper demo-material-design @($"demo-{Model.Id}")">
    <div class="md-app-container">
        
        <!-- App Bar (Elevation 4dp) -->
        <header class="md-app-bar">
            <div class="md-app-bar-nav">
                <button class="md-icon-button" aria-label="Menu">
                    <svg viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
                </button>
                <h3 class="md-title">Material Design Demo</h3>
            </div>
            <div class="md-app-bar-actions">
                <button class="md-icon-button" aria-label="Search">
                    <svg viewBox="0 0 24 24"><path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg>
                </button>
                <button class="md-icon-button" aria-label="More Options">
                    <svg viewBox="0 0 24 24"><path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/></svg>
                </button>
            </div>
        </header>

        <!-- Main Content Area -->
        <main class="md-content">
            
            <div class="md-grid">
                
                <!-- Definition Card (Elevation 1dp -> 8dp on hover) -->
                <div class="md-card">
                    <div class="md-card-header">
                        <div class="md-avatar">MD</div>
                        <div class="md-card-title-group">
                            <h4 class="md-card-title">@Model.Name</h4>
                            <p class="md-card-subtitle">Papel Digital & Tinta</p>
                        </div>
                    </div>
                    <img src="/api/img?seed=material&w=800&h=450" alt="Material Design Hero" class="md-card-media" width="800" height="450" />

                    <div class="md-card-content">
                        <p class="md-body-text">
                            @Model.Description
                        </p>
                    </div>
                    <div class="md-card-actions">
                        <button class="md-btn md-btn-text md-ripple">LEER MÁS</button>
                        <button class="md-btn md-btn-text md-ripple">COMPARTIR</button>
                    </div>
                </div>

                <!-- Secondary Card -->
                <div class="md-card md-card-outlined">
                    <div class="md-card-content">
                        <h5 class="md-headline">Elevación Z</h5>
                        <p class="md-body-text">
                            Las sombras estandarizadas (1dp a 24dp) comunican la jerarquía. La luz proyecta sombras direccionales y ambientales exactas para guiar la atención del usuario.
                        </p>
                        
                        <div class="md-list">
                            <div class="md-list-item md-ripple">
                                <div class="md-list-icon">
                                    <svg viewBox="0 0 24 24" fill="var(--md-primary)"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
                                </div>
                                <div class="md-list-text">
                                    <span class="md-list-primary">Superficies base</span>
                                    <span class="md-list-secondary">Elevación 0dp a 1dp</span>
                                </div>
                            </div>
                            <div class="md-divider"></div>
                            <div class="md-list-item md-ripple">
                                <div class="md-list-icon">
                                    <svg viewBox="0 0 24 24" fill="var(--md-secondary)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>
                                </div>
                                <div class="md-list-text">
                                    <span class="md-list-primary">Componentes flotantes</span>
                                    <span class="md-list-secondary">Elevación 6dp a 24dp</span>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Interactive Controls Card -->
                <div class="md-card">
                    <div class="md-card-content">
                        <h5 class="md-headline">Controles Interactivos</h5>
                        <p class="md-body-text" style="margin-bottom: 24px;">
                            Inputs, switches y botones. La tinta digital responde a la interacción del usuario de manera predecible.
                        </p>

                        <!-- Text Field -->
                        <div class="md-text-field">
                            <input type="text" class="md-input" id="md-demo-input" placeholder=" " autocomplete="one-time-code" spellcheck="false" data-lpignore="true" data-bitwarden-watching="false" />
                            <label for="md-demo-input" class="md-input-label">Ejemplo de texto</label>
                            <div class="md-input-ripple"></div>
                        </div>

                        <!-- Switch -->
                        <div class="md-switch-container">
                            <span class="md-body-text">Recibir notificaciones</span>
                            <label class="md-switch">
                              <input type="checkbox" checked aria-label="Recibir notificaciones" autocomplete="one-time-code" spellcheck="false" data-lpignore="true" data-bitwarden-watching="false">
                              <span class="md-switch-track"></span>
                              <span class="md-switch-thumb md-ripple-center"></span>
                            </label>
                        </div>
                        
                        <div style="margin-top: 32px; display: flex; gap: 16px;">
                            <button class="md-btn md-btn-contained md-ripple">SUSCRIBIRSE</button>
                            <button class="md-btn md-btn-outlined md-ripple">CANCELAR</button>
                        </div>
                    </div>
                </div>

            </div>

        </main>

        <!-- Floating Action Button (FAB) (Elevation 6dp -> 12dp) -->
        <button class="md-fab md-ripple" aria-label="Add">
            <svg viewBox="0 0 24 24"><path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/></svg>
        </button>

        <!-- Snackbar / Toast Notification -->
        <div class="md-snackbar">
            <span class="md-snackbar-text">Material Design inicializado correctamente.</span>
            <button class="md-snackbar-action md-ripple">DESHACER</button>
        </div>

    </div>
</div>
